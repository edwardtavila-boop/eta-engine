# EVOLUTIONARY TRADING ALGO  //  .env.example
# Copy to eta_engine/.env (gitignored) and fill real values before GO.
# Do NOT commit the real .env.
# Decisions source: docs/decisions_v1.json
#
# Broker posture (2026-04-24 operator mandate, see memory/broker_dormancy_mandate.md):
#   * ACTIVE  : IBKR (primary), Tastytrade (fallback)   -- see FUTURES ACTIVE block
#   * DORMANT : Tradovate                               -- funding-blocked, see DORMANT block
#   Flip via eta_engine/venues/router.py DORMANT_BROKERS when funding clears.

# =============================================================================
# TIER-A (DORMANT)  //  TRADOVATE  --  funding-blocked per 2026-04-24 mandate
# =============================================================================
# Values here are NOT loaded for live routing while Tradovate is in
# DORMANT_BROKERS. Kept populated so the adapter + tests stay importable
# and the flip-back is a single-line change in venues/router.py.
# OAuth2 credentials consumed by eta_engine/scripts/authorize_tradovate.py
# and eta_engine/venues/tradovate.py  (keys must match core/secrets.py).
TRADOVATE_USERNAME=                # Tradovate account login (email)
TRADOVATE_PASSWORD=                # Tradovate account password
TRADOVATE_APP_ID=EvolutionaryTradingAlgo  # free-form API-app name you register
TRADOVATE_APP_SECRET=              # API-app secret issued with CID
TRADOVATE_CID=                     # numeric Client ID issued by Tradovate
# Legacy aliases kept for backward compat; safe to leave blank.
TRADOVATE_CLIENT_ID=
TRADOVATE_CLIENT_SECRET=
TRADOVATE_DEVICE_ID=
TRADOVATE_ACCOUNT_ID=

# =============================================================================
# FUTURES ACTIVE  //  IBKR (primary) + TASTYTRADE (fallback)
# =============================================================================
# Both are paper-mode by default. Flip VENUE_TYPE=live once credentials
# are confirmed. These are the ONLY active futures brokers while Tradovate
# is DORMANT (2026-04-24 mandate).
TASTY_VENUE_TYPE=paper
TASTY_API_BASE_URL=https://api.cert.tastyworks.com
TASTY_ACCOUNT_NUMBER=
TASTY_ACCOUNT_NUMBER_FILE=
TASTY_SESSION_TOKEN=
TASTY_SESSION_TOKEN_FILE=

IBKR_VENUE_TYPE=paper
IBKR_CP_BASE_URL=https://127.0.0.1:5000/v1/api
IBKR_ACCOUNT_ID=
IBKR_ACCOUNT_ID_FILE=
IBKR_SYMBOL_CONID_MAP=
IBKR_SYMBOL_CONID_MAP_FILE=
# Example single-symbol override: IBKR_CONID_MNQM6=

# Apex Trader Funding eval account ID (separate from Tradovate account ID)
APEX_ACCOUNT_ID=

# =============================================================================
# TIER-B  //  BYBIT v5  (testnet → mainnet paper → mainnet live)
# =============================================================================
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
BYBIT_TESTNET=1            # 1 for testnet, 0 for mainnet — flipped by go_trigger

# =============================================================================
# ALERTS  //  Pushover primary, email digest, SMS on kill
# =============================================================================
PUSHOVER_USER=
PUSHOVER_TOKEN=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=edward.t.avila@gmail.com
SMTP_PASS=              # app-specific password, not Gmail login

# Activated on live-tiny flip
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# =============================================================================
# FIRM BOARD  //  the_firm_complete integration (already connected via firm_bridge)
# =============================================================================
FIRM_ROUNDTABLE_MODEL=claude-sonnet-4-5
FIRM_ROUNDTABLE_DRY_RUN=1   # 1 for dry run (no API calls), 0 for real

# =============================================================================
# DATA  //  market data sources (optional — synthetic fallback exists)
# =============================================================================
# POLYGON_API_KEY=
# COINBASE_API_KEY=
# COINBASE_API_SECRET=

# =============================================================================
# TELEMETRY  //  observability sinks (optional)
# =============================================================================
# DATADOG_API_KEY=
# LOKI_URL=

# =============================================================================
# OPERATOR  //  who's at the desk
# =============================================================================
OPERATOR_EMAIL=edward.t.avila@gmail.com
OPERATOR_TZ=America/New_York

# =============================================================================
# OBSERVABILITY  //  Supabase decision-journal mirror
# =============================================================================
# obs.supabase_sink mirrors every decision-journal append() to
# public.decision_journal in the project below. Fire-and-forget;
# local JSONL stays authoritative if these are unset.
ETA_SUPABASE_URL=https://ujojpnpzquaiaeoqswrn.supabase.co
ETA_SUPABASE_ANON_KEY=sb_publishable_TTP0tzfxbC5PUpbOtWYAAw_mCsWAOGJ
