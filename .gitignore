# EVOLUTIONARY TRADING ALGO  //  .gitignore
# Never commit real secrets.
.env
.env.local
.env.*.local

# Bar-data hygiene full reports — 100MB+ per run, exceeds pre-commit hook ceiling.
# Slim summaries (*_slim.json) are committed instead.
reports/bar_data_hygiene/baseline_*.json
!reports/bar_data_hygiene/baseline_*_slim.json
reports/bar_data_hygiene/*_full.json
.env.tradovate
.env.tradovate.*
*.key
*.pem

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.hypothesis/
.coverage
.coverage.*

# Venv
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Local one-off diagnostics and scratch probes.
/dev/

# Artifacts that are transient (keep committed reports)
/tmp/
/logs/
/logs/runtime/

# Rotating state-file snapshots (managed by scripts/_backup_state.py)
docs/_backups/

# Synthetic artifacts created by smoke runs of monitor scripts
docs/_synth_*.json
docs/_baseline_test.json
docs/_synthetic_drop.json
docs/_p9_dump.json
docs/tradovate_auth_status.json

# Timestamped runtime artifacts (pattern: *_YYYYMMDDTHHMMSSZ.json).
# Keep committed: README.md, *_latest.json, *_decisions.jsonl. The per-run
# timestamped snapshots are regenerated on every bot/script invocation and
# do not belong in git history -- they balloon the working tree into
# hundreds of untracked files.
docs/broker_connections/*_20[0-9][0-9][0-9][0-9][0-9][0-9]T*Z.json
docs/btc_live/*_20[0-9][0-9][0-9][0-9][0-9][0-9]T*Z.json
docs/btc_live/**/*_20[0-9][0-9][0-9][0-9][0-9][0-9]T*Z.json
docs/btc_paper/*_20[0-9][0-9][0-9][0-9][0-9][0-9]T*Z.json
docs/btc_inventory/*_20[0-9][0-9][0-9][0-9][0-9][0-9]T*Z.json

# Broker-router runtime intents are transient queue files, not source.
docs/btc_live/broker_fleet/*.pending_order.json

# Local BTC Command Center control-action logs. The durable status surfaces live
# under docs/btc_live/*_latest.json; control attempts are runtime events.
docs/btc_live/control/

# OneDrive lock files
*.~lock.*

# Local cache directory (model weights, parquet shards, etc.)
.cache/

# Runtime state directories (persisted across runs but operator-local;
# e.g. kill_switch_latch.json, dashboard_history.json). The path each
# script writes to is configurable via APEX_STATE_DIR; these are the
# repo-local defaults and never belong in git.
/state/
/var/

# Background-process log streams (jarvis_dashboard, etc.). Anything
# written under docs/ as *_stderr.log / *_stdout.log is by definition
# a captured stdio dump, not a committed artifact.
docs/*_stderr.log
docs/*_stdout.log

# Runtime telemetry — written by live JARVIS daemon, not source
docs/decision_journal.jsonl
docs/alerts_log.jsonl
docs/runtime_log.jsonl
docs/drift_watchdog.jsonl
docs/live_data/*.jsonl
docs/live_data/collector_last_run.json
docs/jarvis_live_health.json
docs/jarvis_live_log.jsonl
docs/preflight_dryrun_log.txt
docs/preflight_dryrun_report.json

# Operational baselines — schema lives in docs/strategy_baselines.example.json
docs/strategy_baselines.json

# Stage-2 decommission: legacy command_center (VPS-only, untracked)
command_center/

secrets/
common/
